{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "jdtls": {
      "command": [
        "jdtls",
        "-data",
        "/Volumes/AppData/codebase/naca/.jdtls-workspace"
      ],
      "extensions": [".java"],
      "settings": {
        "java": {
          "configuration": {
            "runtimes": [
              {
                "name": "JavaSE-21",
                "path": "/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home",
                "default": true
              }
            ]
          }
        }
      }
    },
    "st4": {
      "command": [
        "java",
        "-jar",
        "/Volumes/AppData/codebase/st4-lsp-server/target/st4-lsp-server-0.1.0.jar"
      ],
      "extensions": [".st", ".stg"]
    }
  }
}